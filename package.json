{
  "name": "m-project-2",
  "version": "1.0.0",
  "description": "A lightweight to-do web app where users can manage tasks by category. Users can create, view, update, and delete tasks. Each task has a title, description, due date, and category. Includes secure user authentication and persistent task storage.",
  "main": "index.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev-solid": "concurrently \"npm run server\" \"npm run solid\"",
    "server": "node backend/server.js",
    "server-py": "cd backend-py && python app.py",
    "react": "cd frontend && npm start",
    "solid": "cd frontend-sld && npm run dev",
    "setup": "npm run setup-backend && npm run setup-frontend",
    "setup-backend": "npm install",
    "setup-backend-py": "cd backend-py && pip install -r requirements.txt",
    "setup-react": "cd frontend && npm install",
    "setup-solid": "cd frontend-sld && npm install",
    "setup-all": "npm run setup-backend && npm run setup-backend-py && npm run setup-frontend && npm run setup-solid",
    "install-all": "npm run setup-all",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "mysql2": "^3.22.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
